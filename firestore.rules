rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica si el usuario autenticado es super_admin
    function isSuperAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Verifica si el equipo con ese ID pertenece al usuario autenticado
    function ownsEquipo(equipoId) {
      return request.auth != null
        && get(/databases/$(database)/documents/equipos/$(equipoId)).data.ownerId == request.auth.uid;
    }

    // ── Equipos ──────────────────────────────────────────────────
    // Lectura pública: el formulario de assessment carga equipos sin login.
    // Los nombres de equipos no son datos sensibles.
    match /equipos/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSuperAdmin()
                            || (request.auth != null && resource.data.ownerId == request.auth.uid);
    }

    // ── Ciclos ───────────────────────────────────────────────────
    // Lectura pública: el formulario necesita saber el ciclo activo.
    match /ciclos/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSuperAdmin()
                            || (request.auth != null && resource.data.ownerId == request.auth.uid);
    }

    // ── Respuestas ───────────────────────────────────────────────
    // Creación pública: cualquiera puede enviar el assessment.
    // Lectura/eliminación: solo el dueño del equipo o super_admin.
    match /respuestas/{id} {
      allow create: if true;
      allow read, delete: if isSuperAdmin() || ownsEquipo(resource.data.equipoId);
      allow update: if isSuperAdmin() || ownsEquipo(resource.data.equipoId);
    }

    // ── Planes de acción ─────────────────────────────────────────
    // Solo el dueño del equipo asociado o super_admin.
    match /planes/{id} {
      allow read, delete, update: if isSuperAdmin() || ownsEquipo(resource.data.equipoId);
      allow create: if request.auth != null
                    && (isSuperAdmin() || ownsEquipo(request.resource.data.equipoId));
    }

    // ── Usuarios ─────────────────────────────────────────────────
    // Lectura: cualquier autenticado (login necesita leer su propio doc).
    // Escritura: solo super_admin.
    match /usuarios/{uid} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ── Configuración de workspace ────────────────────────────────
    // Lectura pública: el formulario de assessment lee el briefing sin login.
    // Escritura: solo el propio workspace admin.
    match /workspaces/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == id;
    }

    // ── Reportes compartibles ─────────────────────────────────────
    // Lectura pública: stakeholders acceden sin login con el token.
    // Creación: cualquier admin autenticado.
    // Eliminación: solo el owner o super_admin (para revocar).
    match /reportes/{token} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
      allow update: if false;
    }
  }
}
